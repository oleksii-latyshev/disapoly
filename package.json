{
  "name": "disapoly",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "wrangler dev",
    "deploy:server": "wrangler deploy",
    "deploy:pages": "wrangler pages deploy dist --project-name disapoly",
    "deploy:all": "bun run deploy:server && bun run build && bun run deploy:pages",
    "cf-typegen": "wrangler types",
    "build": "tsc -b && vite build",
    "check": "biome check",
    "check:fix": "biome check --write",
    "lint": "biome lint",
    "format": "biome format --write .",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/vite": "^4",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "motion": "^12.42.0",
    "partyserver": "^0.5.8",
    "partysocket": "^1.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "3.8.0",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@cloudflare/workers-types": "^5.20260713.1",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "lefthook": "^2.1.9",
    "typescript": "~6",
    "vite": "^8",
    "vitest": "^4.1.9",
    "wrangler": "^4.105.0"
  }
}
