{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.worker.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023"],
    "module": "esnext",
    // Cloudflare Worker / Durable Object globals (DurableObjectState on `this.ctx`,
    // DurableObjectNamespace, the worker WebSocket/Request/Response, etc.).
    "types": ["@cloudflare/workers-types"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  // party/server.ts pulls in the alias-free game core via relative imports.
  "include": ["party"]
}
